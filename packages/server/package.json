{
  "name": "@starter/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/apiTypes.js",
      "default": "./dist/apiTypes.js",
      "types": "./dist/apiTypes.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "node --watch --import \"data:text/javascript,import { register } from 'node:module'; import { pathToFileURL } from 'node:url'; register('ts-node/esm', pathToFileURL('./'));\" src/cli.ts",
    "test": "vitest --run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@starter/core": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/supertest": "^2.0.12",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
