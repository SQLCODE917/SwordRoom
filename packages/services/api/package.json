{
  "name": "@starter/services-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "pnpm run build && node dist/server.js",
    "test": "vitest --run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@starter/engine": "workspace:*",
    "@starter/services-shared": "workspace:*",
    "@starter/shared": "workspace:*",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
