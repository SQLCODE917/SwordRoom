{
  "name": "character-creation-vertical-slice-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --recursive --if-present --parallel run dev",
    "build": "pnpm --recursive --if-present run build",
    "test": "RUN_LOCAL_DDB_TESTS=1 pnpm --recursive --if-present run test",
    "test:browser": "bash scripts/local/run-browser-tests.sh",
    "test:browser:headed": "pnpm --filter @starter/test-browser-e2e exec playwright test --headed --workers=1",
    "test:browser:ui": "pnpm --filter @starter/test-browser-e2e exec playwright test --ui --workers=1",
    "test:browser:install": "pnpm --filter @starter/test-browser-e2e exec playwright install chromium",
    "type-check": "pnpm --recursive --if-present run type-check",
    "clean": "pnpm --recursive --if-present exec rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
